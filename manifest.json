{
    "manifest_version": 3,
    "name": "AI Explainer",
    "version": "1.0",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://api.groq.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "options_page": "options.html"
}