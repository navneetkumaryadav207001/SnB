{
    "manifest_version": 3,
    "name": "AI Explainer",
    "version": "1.0",
    "description": "Select text and get instant AI explanations powered by Groq",
    "icons": {
        "48": "icon.svg",
        "128": "icon.svg"
    },
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://api.groq.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "options_page": "options.html",
    "action": {
        "default_icon": {
            "48": "icon.svg",
            "128": "icon.svg"
        }
    }
}
