{
    "manifest_version": 3,
    "name": "AI Explainer",
    "version": "1.0",
    "description": "Select text and get instant AI explanations powered by Groq",
    "icons": {
        "48": "icon.svg",
        "128": "icon.svg"
    },
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://api.groq.com/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "vendor/marked.js",
                "vendor/kartex.min.js",
                "vendor/marked-katex-extension.js",
                "utils/text_formatting.js",
                "utils/ui.js",
                "content.js",
                "utils/screenshots.js"
            ],
            "css": [
                "vendor/kartex.min.css",
                "styles.css"
            ]
        }
    ],
    "options_page": "options.html",
    "action": {
        "default_icon": {
            "48": "icon.svg",
            "128": "icon.svg"
        }
    }
}